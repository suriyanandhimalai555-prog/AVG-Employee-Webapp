# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE CONFIG
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/attendance_db"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REDIS CONFIG
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Format: redis://[host]:[port]
REDIS_URL="redis://localhost:6379"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT CONFIG
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Generate a secret: openssl rand -base64 32
JWT_SECRET="your_32_character_long_secret_key_here"
JWT_EXPIRES_IN="8h"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AWS S3 CONFIG (for field photos)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="attendance-photos"
S3_PRESIGN_EXPIRES=300

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SERVER CONFIG
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
